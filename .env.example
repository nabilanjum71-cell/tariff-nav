# ============================================================
# TariffNav — Environment Variables
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to GitHub
# ============================================================

# ── Supabase (free tier) ──────────────────────────────────────
# Get from: https://app.supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Anthropic Claude API (free tier) ─────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── YouTube Data API v3 (free — 10,000 units/day) ────────────
# Get from: https://console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-api-key-here

# ── Vercel Deploy Hook (for triggering rebuilds from GitHub Actions) ──
# Get from: Vercel Dashboard → Your Project → Settings → Git → Deploy Hooks
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/your-hook-id

# ── No other paid services needed ────────────────────────────
# USITC API:           Free, no key required
# WTO Tariff DB:       Free bulk download, no key required
# UN Comtrade API:     Free, no key for basic queries
# Federal Register:    Free, no key required
